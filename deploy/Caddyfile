{
  admin off
  email hello@tripsignal.ca
}

# Shared security headers — used by both prod and staging.
# worker-src blob: is required by Clerk's web worker implementation.
(security_headers) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.clerk.accounts.dev https://clerk.tripsignal.ca https://challenges.cloudflare.com https://us.i.posthog.com https://www.googletagmanager.com https://www.google-analytics.com; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.clerk.com https://img.clerk.com https://www.googletagmanager.com; font-src 'self' data:; connect-src 'self' https://*.clerk.accounts.dev https://clerk.tripsignal.ca https://clerk-telemetry.com https://api.stripe.com https://us.i.posthog.com https://us-assets.i.posthog.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; frame-src https://*.clerk.accounts.dev https://clerk.tripsignal.ca https://js.stripe.com https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'"
  }
}

tripsignal.ca {
  encode zstd gzip
  import security_headers

  handle /api/* {
    request_body {
      max_size 10MB
    }
    reverse_proxy api:8000
  }

  handle /clerk-proxy-api/* {
    uri strip_prefix /clerk-proxy-api
    reverse_proxy https://clerk.tripsignal.ca {
      header_up Host clerk.tripsignal.ca
      header_up Clerk-Proxy-Url https://tripsignal.ca/clerk-proxy-api
      header_up Clerk-Secret-Key {$CLERK_SECRET_KEY}
      header_down Set-Cookie "domain=.clerk.tripsignal.ca" "domain=.tripsignal.ca"
      header_down Set-Cookie "domain=clerk.tripsignal.ca" "domain=.tripsignal.ca"
      header_down Location "https://clerk.tripsignal.ca" "https://tripsignal.ca/clerk-proxy-api"
      transport http {
        tls
      }
    }
  }

  handle {
    reverse_proxy tripsignal-frontend:3000
  }
}

www.tripsignal.ca {
  redir https://tripsignal.ca{uri} permanent
}

staging.tripsignal.ca {
  encode zstd gzip
  import security_headers

  handle /api/* {
    request_body {
      max_size 10MB
    }
    reverse_proxy api:8000
  }

  handle {
    reverse_proxy tripsignal-frontend-staging:3000
  }
}
