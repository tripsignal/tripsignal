{
  admin off
  email hello@tripsignal.ca
}

tripsignal.ca {
  encode zstd gzip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.clerk.accounts.dev https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.clerk.com https://img.clerk.com; font-src 'self' data:; connect-src 'self' https://*.clerk.accounts.dev https://api.stripe.com; frame-src https://*.clerk.accounts.dev https://js.stripe.com https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'"
  }

  handle /api/* {
    request_body {
      max_size 10MB
    }
    reverse_proxy api:8000
  }

  handle {
    reverse_proxy tripsignal-frontend:3000
  }
}

www.tripsignal.ca {
  redir https://tripsignal.ca{uri} permanent
}

staging.tripsignal.ca {
  encode zstd gzip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.clerk.accounts.dev https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.clerk.com https://img.clerk.com; font-src 'self' data:; connect-src 'self' https://*.clerk.accounts.dev https://api.stripe.com; frame-src https://*.clerk.accounts.dev https://js.stripe.com https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'"
  }

  handle /api/* {
    request_body {
      max_size 10MB
    }
    reverse_proxy api:8000
  }

  handle {
    reverse_proxy tripsignal-frontend-staging:3000
  }
}
